APP_NAME="Edatsu Media"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# NOWPayments (USDT / stablecoin checkout). Generate the API key in the
# NOWPayments dashboard. The IPN secret is a separate value used to verify
# webhook signatures (HMAC-SHA512 over sorted JSON). Set the IPN URL in the
# dashboard to https://<your-host>/webhook/nowpayments.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# Girostack (NGN bank transfers via disposable virtual accounts, 30 min TTL).
# DESTINATION_ACCOUNT is the giro parent VBA that funds settle into.
# Webhook posts to /webhook/girostack with HMAC-SHA512 signature in x-giro-signature.
GIRO_BASE_URL=https://gw.prod.girostack.com/v1
GIRO_SECRET_KEY=
GIRO_DESTINATION_ACCOUNT=
GIRO_ACCOUNT_NAME="Edatsu Media"

# Opay (NGN bank transfers — fallback/alternative to Girostack).
# Created at merchant.opaycheckout.com; verify exact API URLs and signature
# scheme against the merchant dashboard once an account is provisioned.
# Webhook posts to /webhook/opay; signature is verified against the private
# key (HMAC-SHA512 over the raw body, header name confirmed in dashboard).
OPAY_BASE_URL=https://liveapi.opaycheckout.com
OPAY_MERCHANT_ID=
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_MERCHANT_NAME="Edatsu Media"

VITE_APP_NAME="${APP_NAME}"
