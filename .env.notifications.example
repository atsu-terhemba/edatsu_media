# ============================================
# EMAIL & NOTIFICATION CONFIGURATION
# ============================================
# Add these to your .env file
# ============================================

# Email Configuration - RESEND (Recommended)
# ---------------------------------
MAIL_MAILER=resend
RESEND_KEY=re_your_api_key_here

# For free tier, use Resend's sending domain:
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME="Edatsu"

# For production with custom domain (after domain verification in Resend):
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="Edatsu"

# Alternative Email Options
# ---------------------------------

# Option 2: Gmail (For Testing/Development only)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # Generate this from Google Account settings
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="Edatsu"

# Option 2: Mailgun (Production Recommended)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SECRET=your-mailgun-key
# MAILGUN_ENDPOINT=api.mailgun.net
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="Edatsu"

# Option 3: Amazon SES (Production)
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
# MAIL_FROM_ADDRESS=noreply@yourdomain.com
# MAIL_FROM_NAME="Edatsu"

# Queue Configuration
# ---------------------------------
QUEUE_CONNECTION=database  # Change to 'redis' for production

# Redis Configuration (if using Redis queue)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Push Notification Configuration
# ---------------------------------

# Firebase Cloud Messaging (Recommended)
# FCM_SERVER_KEY=your-firebase-server-key
# FCM_SENDER_ID=your-firebase-sender-id

# Pusher Beams (Alternative)
# PUSHER_BEAMS_INSTANCE_ID=your-instance-id
# PUSHER_BEAMS_SECRET_KEY=your-secret-key

# ============================================
# SETUP STEPS
# ============================================
# 1. Copy the email settings above to your .env
# 2. Run: php artisan config:clear
# 3. Run: php artisan migrate (if not already done)
# 4. Start queue worker: php artisan queue:work
# 5. Test: php artisan test:reminder-notification
# ============================================
